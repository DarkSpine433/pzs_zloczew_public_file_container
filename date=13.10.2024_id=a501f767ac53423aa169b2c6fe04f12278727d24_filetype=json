                  "detail": 0,
                  "format": 0,
                  "mode": "normal",
                  "style": "",
                  "text": "Uczniowie klasy III br odebrali świadectwa ukończenia szkoły. Doceniono najbardziej zaangażowanych.",
                  "type": "text",
                  "version": 1
                },
